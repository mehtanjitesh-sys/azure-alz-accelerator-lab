# PUBLIC SAMPLE ONLY.
# Copy this file to terraform.tfvars for local testing, then replace the
# placeholder values privately. Never commit real tenant IDs, subscription IDs,
# Entra object IDs, secrets, network details, or production DNS targets.

enterprise_id            = "contoso"
location                 = "eastus"
platform_subscription_id = "00000000-0000-0000-0000-000000000000"
log_analytics_workspace_id = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-contoso-management/providers/Microsoft.OperationalInsights/workspaces/law-contoso"

platform_admin_group_object_id  = "11111111-1111-1111-1111-111111111111"
security_reader_group_object_id = "22222222-2222-2222-2222-222222222222"
break_glass_user_object_ids     = ["33333333-3333-3333-3333-333333333333"]

github_repository_subjects = [
  "repo:mehtanjitesh-sys/azure-alz-accelerator-lab:environment:prod"
]

subscriptions = {
  claims_prod = {
    subscription_id       = "44444444-4444-4444-4444-444444444444"
    management_group_name = "contoso-regulated-prod"
    display_name          = "Claims Production"
    environment           = "prod"
    business_unit         = "claims"
    cost_center           = "CC1045"
    data_classification   = "restricted"
    monthly_budget        = 25000
    owner_group_object_id = "55555555-5555-5555-5555-555555555555"
    connectivity          = "hub-connected"
    workload_route_table_ids = [
      "/subscriptions/44444444-4444-4444-4444-444444444444/resourceGroups/rg-claims-prod-network/providers/Microsoft.Network/routeTables/rt-claims-prod"
    ]
  }
}

spokes = {
  claims_prod = {
    vnet_id        = "/subscriptions/44444444-4444-4444-4444-444444444444/resourceGroups/rg-claims-prod-network/providers/Microsoft.Network/virtualNetworks/vnet-claims-prod"
    vnet_name      = "vnet-claims-prod"
    resource_group = "rg-claims-prod-network"
    subnet_ids = [
      "/subscriptions/44444444-4444-4444-4444-444444444444/resourceGroups/rg-claims-prod-network/providers/Microsoft.Network/virtualNetworks/vnet-claims-prod/subnets/snet-app"
    ]
  }
}

dns_forwarding_rules = {
  on_prem = {
    domain_name = "corp.contoso.com."
    target_dns_servers = [
      {
        ip_address = "10.10.10.10"
      }
    ]
  }
}

default_tags = {
  managed_by = "terraform"
  platform   = "azure-landing-zone"
}
